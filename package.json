{
  "name": "ai-agent-security-monitor",
  "version": "0.1.0",
  "description": "Runtime access control and observability plane for AI agents",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "docker:dev": "docker compose up -d",
    "docker:dev:down": "docker compose down"
  },
  "keywords": [
    "ai-security",
    "agent-governance",
    "mcp",
    "security",
    "compliance"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/swagger": "^9.5.0",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bullmq": "^5.47.0",
    "fastify": "^5.2.0",
    "pino": "^9.6.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "dotenv": "^17.0.0",
    "eslint": "^9.39.4",
    "pg": "^8.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
